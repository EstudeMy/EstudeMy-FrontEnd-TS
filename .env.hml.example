# Configurações do Ambiente de Homologação (HML)
# Renomeie ou copie este arquivo para .env.hml na raiz do projeto

# URL da API do Backend em Homologação (Backend HML roda na porta 5003)
NEXT_PUBLIC_API_URL=http://localhost:5003

# Porta em que o servidor Next.js de HML rodará localmente
PORT=3003
